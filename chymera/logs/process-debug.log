[2026-04-14 12:02:30] [cas9] COUNT SQL: SELECT COUNT(*) AS cnt FROM (
        SELECT
            'cas9'                        AS `Cas Type`,
            t.guide_sequence                AS `Guide Sequence`,
            CONCAT(t.seqnames, ':', t.guideseq_start, '-', t.guideseq_end) AS `Guide Coordinates`,
            CONCAT(t.seqnames, ':', t.start, '-', t.end)                   AS `Cut Site`,
            t.strand                        AS `Targeted Strand`,
            t.pam_sequence                  AS `PAM Sequence`,
            GROUP_CONCAT(DISTINCT a.gene_name  SEPARATOR ', ') AS `Gene Name`,
            GROUP_CONCAT(DISTINCT a.gene_id    SEPARATOR ', ') AS `Gene ID`,
            GROUP_CONCAT(DISTINCT a.strand     SEPARATOR ', ') AS `Gene Strand`,
            GROUP_CONCAT(DISTINCT a.gene_type  SEPARATOR ', ') AS `Target Category`,
            GROUP_CONCAT(DISTINCT a.exon_id    SEPARATOR ', ') AS `Exon ID`,
            MAX(CASE WHEN a.type = 'exon'                        THEN 'TRUE' ELSE 'FALSE' END) AS `Overlap Exon`,
            MAX(CASE WHEN a.type = 'gene' AND a.type != 'exon'  THEN 'TRUE' ELSE 'FALSE' END) AS `Overlap Intron`,
            MAX(CASE WHEN a.type LIKE '%UTR%'                    THEN 'TRUE' ELSE 'FALSE' END) AS `Overlap UTR`,
            MAX(CASE WHEN a.type = 'CDS'                         THEN 'TRUE' ELSE 'FALSE' END) AS `Overlap CDS`,
            IF(COUNT(DISTINCT a.gene_name) > 1, 'TRUE', 'FALSE')                               AS `Overlap 2nd Gene`,
            t.h0 + t.h1 + t.h2 + t.h3      AS `Number Of Off-Targets`,
            t.h0 AS Hamming_0, t.h1 AS Hamming_1, t.h2 AS Hamming_2, t.h3 AS Hamming_3,
            t.specificity, t.classification
            ,
           t.RS3_seq                           AS `RS3 Seq`,
           t.RS3_target                        AS `RS3 Target`,
           t.RS3_seq_target                    AS `RS3 Seq Target`
        FROM human_cas9 t
        INNER JOIN human_annot a
            ON  a.seqnames = t.seqnames
            AND a.start    <= t.end
            AND a.end      >= t.start
        WHERE 
        t.seqnames = 'chr1'
        AND (t.end BETWEEN 94530000 AND 94542000 OR t.start BETWEEN 94530000 AND 94542000)
    
        GROUP BY t.guide_sequence, t.start, t.end
    ) base
